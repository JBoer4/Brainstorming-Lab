            <column caption='Win Rate' datatype='real' name='[Calculation_0214735871303680]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='Sum(IF [result]=&apos;win&apos; THEN 1 else 0 end)/ COUNT([result])' />
